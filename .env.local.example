# Claude API key (van Vercel environment variables, heet "CLAUDE_API_KEY")
CLAUDE_API_KEY=your_claude_api_key_here

# Wachtwoord voor inloggen op de tool
AUTH_PASSWORD=kies_een_sterk_wachtwoord

# Willekeurige geheime string voor JWT-signing (minimaal 32 tekens)
# Genereer met: openssl rand -base64 32
AUTH_SECRET=een_willekeurige_geheime_string_van_minimaal_32_tekens
